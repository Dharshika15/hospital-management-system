rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: get user role from Firestore
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    function isDoctor() {
      return isAuth() && getRole() == 'doctor';
    }

    function isPharmacy() {
      return isAuth() && getRole() == 'pharmacy';
    }

    function isReceptionist() {
      return isAuth() && getRole() == 'receptionist';
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
      // Users can read their own profile
      allow read: if request.auth.uid == userId;
    }

    // Patients collection
    match /patients/{patientId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isReceptionist();
      allow update: if isAdmin() || isReceptionist() || isDoctor();
      allow delete: if isAdmin();
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isReceptionist();
      allow update: if isAuth();
      allow delete: if isAdmin() || isReceptionist();
    }

    // Medicines collection
    match /medicines/{medicineId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isPharmacy();
    }

    // Prescriptions collection
    match /prescriptions/{prescriptionId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isDoctor();
      allow update: if isAdmin() || isPharmacy();
    }

    // Revenue collection
    match /revenue/{revenueId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isReceptionist() || isPharmacy();
    }

    // Expenses collection
    match /expenses/{expenseId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || isReceptionist();
      allow create: if isAdmin() || isReceptionist();
    }

    // Dispensations collection
    match /dispensations/{dispensationId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isPharmacy();
    }
    match /doctorSchedules/{docId} {
      allow read: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Logs - admin read only, system write
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuth();
    }
  }
}
